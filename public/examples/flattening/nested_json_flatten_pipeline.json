{
  "name": "Nested JSON to Table",
  "description": "Flatten complex nested JSON structures into tabular format with parent fields",
  "nodes": [
    {
      "id": "input-1",
      "type": "input",
      "position": {
        "x": 100,
        "y": 150
      },
      "data": {
        "label": "Nested JSON",
        "subtype": "csv",
        "config": {
          "file_path": "examples/nested_data.json",
          "sample_data": [
            {
              "id": 1,
              "name": "Order 1",
              "response": {
                "metadata": {
                  "created_at": "2024-01-15T10:00:00Z",
                  "updated_at": "2024-01-15T11:00:00Z"
                },
                "items": [
                  {
                    "item_id": "A1",
                    "quantity": 2,
                    "price": 25.50
                  }
                ]
              }
            }
          ]
        }
      }
    },
    {
      "id": "transform-1",
      "type": "default",
      "position": {
        "x": 400,
        "y": 150
      },
      "data": {
        "label": "Extract First Level",
        "subtype": "raw_sql",
        "config": {
          "sql": "SELECT * FROM {{input}}"
        }
      }
    },
    {
      "id": "transform-2",
      "type": "default",
      "position": {
        "x": 700,
        "y": 150
      },
      "data": {
        "label": "Unnest Items Array",
        "subtype": "raw_sql",
        "config": {
          "sql": "SELECT \n  id,\n  name,\n  \"response.metadata.created_at\" as created_at,\n  \"response.metadata.updated_at\" as updated_at,\n  unnest(json_extract(\"response.items\", '$$')) as item\nFROM {{input}}"
        }
      }
    },
    {
      "id": "transform-3",
      "type": "default",
      "position": {
        "x": 1000,
        "y": 150
      },
      "data": {
        "label": "Extract Nested Fields",
        "subtype": "raw_sql",
        "config": {
          "sql": "SELECT \n  id,\n  name,\n  created_at,\n  updated_at,\n  item->>'$.item_id' as item_id,\n  CAST(item->>'$.quantity' AS INTEGER) as quantity,\n  CAST(item->>'$.price' AS DOUBLE) as price\nFROM {{input}}"
        }
      }
    },
    {
      "id": "transform-4",
      "type": "default",
      "position": {
        "x": 1300,
        "y": 150
      },
      "data": {
        "label": "Add Line Total",
        "subtype": "raw_sql",
        "config": {
          "sql": "SELECT \n  id,\n  name,\n  created_at,\n  updated_at,\n  item_id,\n  quantity,\n  price,\n  quantity * price as line_total\nFROM {{input}}\nORDER BY id, item_id"
        }
      }
    },
    {
      "id": "output-1",
      "type": "output",
      "position": {
        "x": 1600,
        "y": 150
      },
      "data": {
        "label": "Save Flattened Data",
        "subtype": "db_write",
        "config": {
          "tableName": "flattened_orders",
          "filename": "orders_flat.csv"
        }
      }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "input-1",
      "target": "transform-1"
    },
    {
      "id": "e2",
      "source": "transform-1",
      "target": "transform-2"
    },
    {
      "id": "e3",
      "source": "transform-2",
      "target": "transform-3"
    },
    {
      "id": "e4",
      "source": "transform-3",
      "target": "transform-4"
    },
    {
      "id": "e5",
      "source": "transform-4",
      "target": "output-1"
    }
  ]
}