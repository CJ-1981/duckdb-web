{
  "name": "Simple JSON Field Extraction",
  "description": "Extract fields from JSON without complex nested arrays",
  "nodes": [
    {
      "id": "input-1",
      "type": "input",
      "position": {
        "x": 100,
        "y": 150
      },
      "data": {
        "label": "JSON Orders",
        "subtype": "csv",
        "config": {
          "file_path": "examples/nested_data.json",
          "sample_data": [
            {
              "id": 1,
              "name": "Order 1",
              "total": 125.00
            }
          ]
        }
      }
    },
    {
      "id": "transform-1",
      "type": "default",
      "position": {
        "x": 400,
        "y": 150
      },
      "data": {
        "label": "Extract Metadata Fields",
        "subtype": "raw_sql",
        "config": {
          "sql": "SELECT \n  id,\n  name,\n  \"response.metadata.created_at\" as created_at,\n  \"response.metadata.updated_at\" as updated_at\nFROM {{input}}"
        }
      }
    },
    {
      "id": "transform-2",
      "type": "default",
      "position": {
        "x": 700,
        "y": 150
      },
      "data": {
        "label": "Add Order Summary",
        "subtype": "raw_sql",
        "config": {
          "sql": "SELECT \n  id,\n  name,\n  created_at,\n  updated_at,\n  'Processed order ' || id as summary,\n  LENGTH(created_at) as timestamp_length\nFROM {{input}}\nORDER BY id"
        }
      }
    },
    {
      "id": "output-1",
      "type": "output",
      "position": {
        "x": 1000,
        "y": 150
      },
      "data": {
        "label": "Save Processed Data",
        "subtype": "csv",
        "config": {
          "filename": "processed_orders.csv"
        }
      }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "input-1",
      "target": "transform-1"
    },
    {
      "id": "e2",
      "source": "transform-1",
      "target": "transform-2"
    },
    {
      "id": "e3",
      "source": "transform-2",
      "target": "output-1"
    }
  ]
}
