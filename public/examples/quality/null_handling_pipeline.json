{
  "name": "Null Handling Strategies",
  "description": "Demonstrate various techniques for handling missing and null values in data",
  "nodes": [
    {
      "id": "input-1",
      "type": "input",
      "position": {"x": 100, "y": 100},
      "data": {
        "label": "Messy Data with Nulls",
        "subtype": "csv",
        "config": {
          "file_path": "examples/messy_data.csv",
          "sample_data": [
            {"id": "C001", "name": "John Doe", "email": "john@example.com", "phone": null, "amount": 35},
            {"id": "C002", "name": null, "email": "jane@example.com", "phone": "555-1234", "amount": 28},
            {"id": "C003", "name": "Bob Smith", "email": null, "phone": null, "amount": null},
            {"id": "C004", "name": "Alice Johnson", "email": "alice@example.com", "phone": "555-5678", "amount": 42}
          ]
        }
      }
    },
    {
      "id": "transform-1",
      "type": "default",
      "position": {"x": 400, "y": 50},
      "data": {
        "label": "Forward Fill",
        "subtype": "raw_sql",
        "config": {
          "sql": "SELECT \n  id,\n  COALESCE(name, 'Unknown') as name,\n  email,\n  phone,\n  amount\nFROM {{input}}\nORDER BY id"
        }
      }
    },
    {
      "id": "transform-2",
      "type": "default",
      "position": {"x": 400, "y": 175},
      "data": {
        "label": "Backward Fill",
        "subtype": "raw_sql",
        "config": {
          "sql": "SELECT \n  id,\n  name,\n  COALESCE(email, 'no_email@example.com') as email,\n  phone,\n  amount\nFROM {{input}}\nORDER BY id"
        }
      }
    },
    {
      "id": "transform-3",
      "type": "default",
      "position": {"x": 400, "y": 300},
      "data": {
        "label": "Default Values",
        "subtype": "raw_sql",
        "config": {
          "sql": "SELECT \n  id,\n  name,\n  email,\n  COALESCE(phone, 'N/A') as phone,\n  COALESCE(amount, 0) as amount\nFROM {{input}}\nORDER BY id"
        }
      }
    },
    {
      "id": "aggregate-1",
      "type": "default",
      "position": {"x": 700, "y": 175},
      "data": {
        "label": "Null Statistics",
        "subtype": "aggregate",
        "config": {
          "groupBy": null,
          "aggregations": [
            {"column": "*", "operation": "COUNT", "alias": "total_rows"},
            {"column": "name", "operation": "COUNT", "alias": "non_null_names"},
            {"column": "email", "operation": "COUNT", "alias": "non_null_emails"},
            {"column": "phone", "operation": "COUNT", "alias": "non_null_phones"}
          ]
        }
      }
    },
    {
      "id": "output-1",
      "type": "output",
      "position": {"x": 1000, "y": 175},
      "data": {
        "label": "Save Cleaned Data",
        "subtype": "csv",
        "config": {
          "filename": "cleaned_customers.csv"
        }
      }
    }
  ],
  "edges": [
    {"id": "e1", "source": "input-1", "target": "transform-1"},
    {"id": "e2", "source": "input-1", "target": "transform-2"},
    {"id": "e3", "source": "input-1", "target": "transform-3"},
    {"id": "e4", "source": "transform-1", "target": "aggregate-1"},
    {"id": "e5", "source": "aggregate-1", "target": "output-1"}
  ]
}
