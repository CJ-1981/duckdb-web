{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run test:e2e",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui -c tests/e2e/playwright.config.ts",
    "test:e2e:debug": "playwright test --debug -c tests/e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --headed -c tests/e2e/playwright.config.ts",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
