# npm configuration for Windows environments
# This file ensures consistent behavior across different Windows setups

# Use npm's built-in package manager instead of yarn
package-manager=npm

# Prevent npm from writing invalid JSON (Windows-specific)
# Windows can have issues with Unicode in package.json
strict-ssl=false
# Note: Only disable strict SSL if you're behind a corporate proxy
# For production, keep strict-ssl=true and configure proxy properly

# Python executable for Python-based dependencies
# Uncomment and adjust if Python is not in PATH
# python=C:\Python312\python.exe

# Node.js options for Windows
# Prevents issues with long paths on Windows
# Remove this if using Windows 10+ with long path support enabled
# fund=false

# Cache configuration for Windows
# Use a shorter path ONLY if you have write access to it
# cache=C:\npm-cache

# Log level for better debugging on Windows
loglevel=warn

# Save exact versions (better for Windows environments)
save-exact=true

# Engine strict mode - ensure Node version compatibility
engine-strict=true
